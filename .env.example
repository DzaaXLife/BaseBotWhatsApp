# ─── WhatsApp Bot Configuration ────────────────────────────────────────────────

# Connection method: "qr" or "pairing"
CONNECT_METHOD=qr

# Required only when CONNECT_METHOD=pairing
# Format: country_code + phone (no + or spaces), e.g. 6281234567890
PHONE_NUMBER=

# SQLite database path for session storage
DB_PATH=./data/sessions.db

# Command prefix
BOT_PREFIX=!

# Bot name (displayed in help)
BOT_NAME=GoBot

# Your JID (optional, used for owner-only commands)
# Format: 6281234567890@s.whatsapp.net
OWNER_JID=

# Auto-reconnect on disconnect (true/false)
AUTO_RECONNECT=true
